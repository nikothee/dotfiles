// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "redact_private_values": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "mistral-vibe": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "outline_panel": {
    "dock": "right",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": false,
      "provider": "mistral",
      "model": "codestral-latest",
    },
    "favorite_models": [
      {
        "provider": "mistral",
        "model": "codestral-latest",
        "enable_thinking": false
      }
    ],
    "model_parameters": [],
  },
  "icon_theme": "Material Icon Theme",
  "terminal": {
    "shell": "system",
    "font_family": "SpaceMono Nerd Font",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "auto",
    "max_width_columns": 100,
  },
  "current_line_highlight": "gutter",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_fallbacks": ["SpaceMono Nerd Font"],
  "buffer_font_family": "SpaceMono Nerd Font",
  "show_whitespaces": "trailing",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [80, 100],
  "preferred_line_length": 100,
  "soft_wrap": "bounded",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "GitHub Light",
    "dark": "GitHub Dark",
  },
}
